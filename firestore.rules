rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /blogPosts/{docId} {
      allow read: if isSignedIn() || resource.data.published == true;
      allow write: if isSignedIn();
    }

    match /announcements/{docId} {
      allow read: if isSignedIn() || resource.data.active == true;
      allow write: if isSignedIn();
    }

    match /projects/{docId} {
      allow read: if isSignedIn() || resource.data.published == true;
      allow write: if isSignedIn();
    }

    match /testimonials/{docId} {
      allow read: if isSignedIn() || resource.data.featured == true || resource.data.published == true;
      allow write: if isSignedIn();
    }

    match /resources/{docId} {
      allow read: if isSignedIn() || resource.data.published == true;
      allow write: if isSignedIn();
    }

    match /aiPrompts/{docId} {
      allow read, write: if isSignedIn();
    }

    match /antiConceptDiagnostic/{docId} {
      allow read: if isSignedIn() || resource.data.active == true;
      allow write: if isSignedIn();
    }

    match /legalDocuments/{docId} {
      allow read: if isSignedIn() || resource.data.published == true;
      allow write: if isSignedIn();
    }

    match /sitemapEntries/{docId} {
      allow read: if isSignedIn() || resource.data.indexed == true;
      allow write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
